{
  "name": "@sorafujitani/memoli",
  "version": "0.0.6",
  "description": "CLI markdown memo manager",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sorafujitani/memoli.git"
  },
  "bin": {
    "memoli": "./bin/memoli"
  },
  "files": [
    "bin",
    "scripts/postinstall.cjs"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "build": "bun run scripts/build.ts",
    "release": "bun run scripts/release.ts",
    "check": "NODE_OPTIONS='--experimental-strip-types --no-warnings' vp check",
    "test": "vp test",
    "lint": "NODE_OPTIONS='--experimental-strip-types --no-warnings' vp lint",
    "fmt": "NODE_OPTIONS='--experimental-strip-types --no-warnings' vp fmt",
    "fmt:check": "NODE_OPTIONS='--experimental-strip-types --no-warnings' vp fmt --check"
  },
  "dependencies": {
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vite-plus": "^0.1.11"
  }
}
